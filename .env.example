# Copia este archivo como ".env" y ajusta los valores para tu entorno local.
# El archivo ".env" real NUNCA debe subirse al repositorio (ver .gitignore).

DB_HOST=localhost
DB_NAME=eventos_deportivos
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Llave secreta para las firmas HMAC-SHA256 de integridad (actividades y facturas).
# Genera una propia y unica para produccion, por ejemplo con:
#   php -r "echo bin2hex(random_bytes(32));"
APP_HMAC_KEY=CAMBIAR_ESTA_LLAVE_EN_PRODUCCION_2026
